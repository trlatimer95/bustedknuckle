---

---

<section id="contact" class="py-20 sm:py-28 bg-brand-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="w-12 h-1 bg-accent-500 mx-auto mb-6"></div>
      <h2 class="font-heading font-800 text-3xl sm:text-4xl md:text-5xl text-white tracking-wider">
        Get in Touch
      </h2>
      <p class="mt-4 text-warm-300 text-lg max-w-2xl mx-auto">
        Ready to start your project? Drop us a line or give us a call. We'd love to hear about your build.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-8">
      <!-- Contact Form (3 cols) -->
      <div class="lg:col-span-3">
        <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6" id="contact-form">
          <!-- Web3Forms Access Key - replace with actual key -->
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY" />
          <input type="hidden" name="subject" value="New inquiry from Busted Knuckle website" />
          <input type="hidden" name="from_name" value="Busted Knuckle Website" />
          <!-- Honeypot -->
          <input type="checkbox" name="botcheck" class="hidden" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-warm-300 text-sm font-heading tracking-wider uppercase mb-2">Name *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-brand-700/50 border border-brand-600 rounded-sm px-4 py-3 text-warm-100 placeholder-warm-400/50 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500 transition-colors"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="phone" class="block text-warm-300 text-sm font-heading tracking-wider uppercase mb-2">Phone</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full bg-brand-700/50 border border-brand-600 rounded-sm px-4 py-3 text-warm-100 placeholder-warm-400/50 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500 transition-colors"
                placeholder="(208) 555-0000"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-warm-300 text-sm font-heading tracking-wider uppercase mb-2">Email *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-brand-700/50 border border-brand-600 rounded-sm px-4 py-3 text-warm-100 placeholder-warm-400/50 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500 transition-colors"
              placeholder="you@example.com"
            />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="service" class="block text-warm-300 text-sm font-heading tracking-wider uppercase mb-2">Service Interest</label>
              <select
                id="service"
                name="service"
                class="w-full bg-brand-700/50 border border-brand-600 rounded-sm px-4 py-3 text-warm-100 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500 transition-colors"
              >
                <option value="" class="bg-brand-700">Select a service</option>
                <option value="Custom Paint" class="bg-brand-700">Custom Paint & Color</option>
                <option value="Body Repair" class="bg-brand-700">Auto Body Repair</option>
                <option value="Restoration" class="bg-brand-700">Full Restoration</option>
                <option value="General Repair" class="bg-brand-700">General Auto Repair</option>
                <option value="Other" class="bg-brand-700">Other</option>
              </select>
            </div>
            <div>
              <label for="vehicle" class="block text-warm-300 text-sm font-heading tracking-wider uppercase mb-2">Vehicle Info</label>
              <input
                type="text"
                id="vehicle"
                name="vehicle"
                class="w-full bg-brand-700/50 border border-brand-600 rounded-sm px-4 py-3 text-warm-100 placeholder-warm-400/50 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500 transition-colors"
                placeholder="Year, Make, Model"
              />
            </div>
          </div>

          <div>
            <label for="message" class="block text-warm-300 text-sm font-heading tracking-wider uppercase mb-2">Message *</label>
            <textarea
              id="message"
              name="message"
              required
              rows="4"
              class="w-full bg-brand-700/50 border border-brand-600 rounded-sm px-4 py-3 text-warm-100 placeholder-warm-400/50 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500 transition-colors resize-none"
              placeholder="Tell us about your project..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full sm:w-auto bg-accent-500 hover:bg-accent-400 text-white px-8 py-4 rounded-sm font-heading font-700 text-base tracking-widest uppercase transition-colors"
          >
            Send Message
          </button>

          <!-- Success/Error Messages -->
          <div id="form-success" class="hidden text-green-400 text-sm mt-2">
            Thanks! Your message has been sent. We'll get back to you soon.
          </div>
          <div id="form-error" class="hidden text-red-400 text-sm mt-2">
            Something went wrong. Please call us at (208) 553-6155 instead.
          </div>
        </form>
      </div>

      <!-- Contact Info Sidebar (2 cols) -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Address -->
        <div class="flex gap-4">
          <div class="text-accent-500 shrink-0 mt-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-600 text-white tracking-wider text-sm uppercase">Address</h3>
            <p class="text-warm-300 mt-1">
              3737 14th Street East<br />
              Lewiston, ID 83501
            </p>
          </div>
        </div>

        <!-- Phone -->
        <div class="flex gap-4">
          <div class="text-accent-500 shrink-0 mt-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-600 text-white tracking-wider text-sm uppercase">Phone</h3>
            <a href="tel:+12085536155" class="text-accent-400 hover:text-accent-300 mt-1 inline-block transition-colors">
              (208) 553-6155
            </a>
          </div>
        </div>

        <!-- Facebook -->
        <div class="flex gap-4">
          <div class="text-accent-500 shrink-0 mt-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-600 text-white tracking-wider text-sm uppercase">Follow Us</h3>
            <a
              href="https://www.facebook.com/profile.php?id=61565656770852"
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent-400 hover:text-accent-300 mt-1 inline-block transition-colors"
            >
              Facebook
            </a>
          </div>
        </div>

        <!-- Map -->
        <div class="mt-8 rounded-sm overflow-hidden border border-brand-600/50 aspect-[4/3]">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2750!2d-116.9632!3d46.4004!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDbCsDI0JzAxLjQiTiAxMTbCsDU3JzQ3LjUiVw!5e0!3m2!1sen!2sus!4v1"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Busted Knuckle Auto Repair location in Lewiston, Idaho"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
      });

      if (response.ok) {
        successMsg?.classList.remove('hidden');
        form.reset();
      } else {
        errorMsg?.classList.remove('hidden');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
    }
  });
</script>
