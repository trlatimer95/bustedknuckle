      { src: `${base}images/ram2500before.jpg`, caption: 'Before' },
      { src: `${base}images/ram2500after.jpg`,  caption: 'After' },
    ],
  },
  {
    id: 'dodge',
    title: 'Dodge Ram 2500',
    category: 'body',
    description: 'Fender flare install and body work on a lifted Ram 2500.',
    cover: `${base}images/dodgeAfter2.jpg`,
    images: [
      { src: `${base}images/dodgeBefore1.jpg`, caption: 'Before' },
      { src: `${base}images/dodgeBefore2.jpg`, caption: 'Before — rolling shot' },
      { src: `${base}images/dodgeAfter1.jpg`,  caption: 'After — fender flares' },
      { src: `${base}images/dodgeAfter2.jpg`,  caption: 'After — side profile' },
    ],
  },
  {
    id: 'brakes',
    title: 'Brake Service',
    category: 'repair',
    description: 'Rotor and brake replacement — safety first.',
    cover: `${base}images/brakesAfter.jpg`,
    images: [
      { src: `${base}images/brakesBefore.jpg`, caption: 'Before — worn rotors' },
      { src: `${base}images/brakesAfter.jpg`,  caption: 'After — fresh rotors' },
    ],
  },
];

const categories = [
  { label: 'All',         value: 'all' },
  { label: 'Restoration', value: 'restoration' },
  { label: 'Build',       value: 'build' },
  { label: 'Paint',       value: 'paint' },
  { label: 'Body Work',   value: 'body' },
  { label: 'Repair',      value: 'repair' },
];

// Merge all projects for lightbox data
const allProjects = [...featured, ...projects];
---

<section id="portfolio" class="py-20 sm:py-28 bg-brand-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center mb-12">
      <div class="w-12 h-1 bg-accent-500 mx-auto mb-6"></div>
      <h2 class="font-heading font-800 text-3xl sm:text-4xl md:text-5xl text-white tracking-wider">
        Our Work
      </h2>
      <p class="mt-4 text-warm-300 text-lg max-w-2xl mx-auto">
        Every project tells a story. Here's a look at some of the builds, restorations, and repairs that have rolled through our shop.
      </p>
    </div>

    <!-- Filter Buttons -->
    <div class="flex flex-wrap justify-center gap-3 mb-10">
      {categories.map((cat) => (
        <button
          data-filter={cat.value}
          class:list={[
            'portfolio-filter font-heading text-sm tracking-widest uppercase px-5 py-2 rounded-sm border transition-all duration-300',
            cat.value === 'all'
              ? 'bg-accent-500 border-accent-500 text-white'
              : 'border-brand-500 text-warm-400 hover:border-accent-500 hover:text-accent-400',
          ]}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Featured Projects (large cards) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
      {featured.map((project) => (
        <div data-category={project.category} class="portfolio-item group">
          <div
            class="relative overflow-hidden rounded-sm aspect-[4/3] cursor-pointer"
            data-project={project.id}
            role="button"
            tabindex="0"
            aria-label={`View ${project.title} gallery`}
          >
            <img
              src={project.cover}
              alt={project.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-900 via-brand-900/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-300"></div>
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="w-14 h-14 rounded-full bg-accent-500/90 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" />
                </svg>
              </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-6">
              <span class="inline-block bg-accent-500 text-white text-xs font-heading font-700 tracking-widest uppercase px-2 py-0.5">{project.category}</span>
              <h3 class="font-heading font-700 text-xl sm:text-2xl text-white tracking-wider mt-2">
                {project.title}
              </h3>
              <p class="text-warm-300 text-sm mt-2 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                {project.description}
              </p>
            </div>
          </div>
          <!-- Thumbnail strip -->
          <div class="grid grid-cols-6 gap-1 mt-1">
            {project.images.map((img, i) => (
              <button
                class="thumbnail-btn aspect-square overflow-hidden rounded-sm opacity-60 hover:opacity-100 transition-opacity duration-200 focus:outline-none focus:ring-2 focus:ring-accent-500"
                data-project={project.id}
                data-index={i}
                aria-label={img.caption}
              >
                <img src={img.src} alt={img.caption} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Additional Projects (3-column grid) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {projects.map((project) => (
        <div data-category={project.category} class="portfolio-item group">
          <div
            class="relative overflow-hidden rounded-sm aspect-[4/3] cursor-pointer"
            data-project={project.id}
            role="button"
            tabindex="0"
            aria-label={`View ${project.title} gallery`}
          >
            <img
              src={project.cover}
              alt={project.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-900 via-brand-900/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-300"></div>
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="w-12 h-12 rounded-full bg-accent-500/90 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                </svg>
              </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <span class="inline-block bg-accent-500 text-white text-xs font-heading font-700 tracking-widest uppercase px-2 py-0.5">{project.category}</span>
              <h3 class="font-heading font-700 text-lg text-white tracking-wider mt-2">
                {project.title}
              </h3>
              <p class="text-warm-300 text-xs mt-1 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                {project.description}
              </p>
            </div>
          </div>
          <!-- Thumbnail strip -->
          {project.images.length > 1 && (
            <div class={`grid gap-1 mt-1`} style={`grid-template-columns: repeat(${project.images.length}, 1fr)`}>
              {project.images.map((img, i) => (
                <button
                  class="thumbnail-btn aspect-square overflow-hidden rounded-sm opacity-60 hover:opacity-100 transition-opacity duration-200 focus:outline-none focus:ring-2 focus:ring-accent-500"
                  data-project={project.id}
                  data-index={i}
                  aria-label={img.caption}
                >
                  <img src={img.src} alt={img.caption} class="w-full h-full object-cover" />
                </button>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a
        href="https://www.facebook.com/profile.php?id=61565656770852"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-accent-400 hover:text-accent-300 font-heading font-600 tracking-widest uppercase text-sm transition-colors"
      >
        See more on Facebook
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- Lightbox -->
<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden bg-black/95 flex items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-label="Image lightbox"
>
  <button id="lightbox-close" class="absolute top-4 right-4 text-warm-400 hover:text-white transition-colors z-10" aria-label="Close">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <button id="lightbox-prev" class="absolute left-2 sm:left-6 text-warm-400 hover:text-white transition-colors z-10" aria-label="Previous image">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>

  <div class="flex flex-col items-center max-w-5xl w-full">
    <img id="lightbox-img" src="" alt="" class="max-h-[80vh] max-w-full object-contain rounded-sm" />
    <p id="lightbox-caption" class="text-warm-300 text-sm mt-4 font-heading tracking-wide"></p>
    <p id="lightbox-counter" class="text-warm-500 text-xs mt-1"></p>
  </div>

  <button id="lightbox-next" class="absolute right-2 sm:right-6 text-warm-400 hover:text-white transition-colors z-10" aria-label="Next image">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>
</div>

<script>
  const base = document.querySelector('meta[name="base-url"]')?.getAttribute('content') ?? '/bustedknuckle/';

  const projectData: Record<string, { src: string; caption: string }[]> = {
    camaro: [
      { src: `${base}images/camaro/camaro-01-before.jpg`,        caption: 'Before — original blue paint' },
      { src: `${base}images/camaro/camaro-02-stripped.jpg`,      caption: 'Stripped down in the shop' },
      { src: `${base}images/camaro/camaro-03-rust-repair.jpg`,   caption: 'Rust repair underway' },
      { src: `${base}images/camaro/camaro-04-paint-booth.jpg`,   caption: 'Panels in the paint booth' },
      { src: `${base}images/camaro/camaro-05-finished-side.jpg`, caption: 'Fresh orange — side profile' },
      { src: `${base}images/camaro/camaro-06-finished-front.jpg`,caption: 'Finished — straight-on front' },
    ],
    '4runner': [
      { src: `${base}images/4runner/4runner-01-before.jpg`,   caption: 'Arrived on the trailer' },
      { src: `${base}images/4runner/4runner-02-stripped.jpg`, caption: 'Stripped to bare shell' },
      { src: `${base}images/4runner/4runner-03-paint.jpg`,    caption: 'Fresh paint, reassembly begins' },
      { src: `${base}images/4runner/4runner-04-build.jpg`,    caption: 'Lift and tires going on' },
      { src: `${base}images/4runner/4runner-05-show.jpg`,     caption: 'First show appearance' },
      { src: `${base}images/4runner/4runner-06-finished.jpg`, caption: 'Finished and ready to wheel' },
    ],
    semi: [
      { src: `${base}images/truckBefore.jpg`,  caption: 'Before' },
      { src: `${base}images/truckDuring.jpg`,  caption: 'In the booth' },
      { src: `${base}images/truckAfter1.jpg`,  caption: 'After — driver side' },
      { src: `${base}images/truckAfter2.jpg`,  caption: 'After — detail' },
    ],
    ranger: [
      { src: `${base}images/rangerBefore1.jpg`, caption: 'Before' },
      { src: `${base}images/rangerBefore2.jpg`, caption: 'Before — detail' },
      { src: `${base}images/rangerAfter.jpg`,   caption: 'After' },
    ],
    tacoma2: [
      { src: `${base}images/tacoma2Before1.jpg`, caption: 'Before' },
      { src: `${base}images/tacoma2Before2.jpg`, caption: 'Before — detail' },
      { src: `${base}images/tacoma2Before3.jpg`, caption: 'Before — rear' },
      { src: `${base}images/tacoma2After1.jpg`,  caption: 'After' },
      { src: `${base}images/tacoma2After2.jpg`,  caption: 'After — detail' },
      { src: `${base}images/tacoma2After3.jpg`,  caption: 'After — rear' },
    ],
    pickup: [
      { src: `${base}images/pickupBefore1.jpg`, caption: 'Before' },
      { src: `${base}images/pickupBefore2.jpg`, caption: 'Before — detail' },
      { src: `${base}images/pickupBefore3.jpg`, caption: 'Before — rear' },
      { src: `${base}images/pickupAfter1.jpg`,  caption: 'After' },
      { src: `${base}images/pickupAfter2.jpg`,  caption: 'After — detail' },
    ],
    f350: [
      { src: `${base}images/f350Before.jpg`,  caption: 'Before' },
      { src: `${base}images/f350during.jpg`,  caption: 'During repair' },
      { src: `${base}images/f350after.jpg`,   caption: 'After' },
    ],
    f150: [
      { src: `${base}images/f150before.jpg`,  caption: 'Before' },
      { src: `${base}images/f150before2.jpg`, caption: 'Before — detail' },
      { src: `${base}images/f150during.jpg`,  caption: 'During repair' },
      { src: `${base}images/f150after.jpg`,   caption: 'After' },
    ],
    gmc: [
      { src: `${base}images/gmcbefore1.jpg`, caption: 'Before' },
      { src: `${base}images/gmcbefore2.jpg`, caption: 'Before — detail' },
      { src: `${base}images/gmcafter.jpg`,   caption: 'After' },
    ],
    tacoma: [
      { src: `${base}images/tacomaBefore.jpg`, caption: 'Before' },
      { src: `${base}images/tacomaAfter.jpg`,  caption: 'After' },
    ],
    ram: [
      { src: `${base}images/ram2500before.jpg`, caption: 'Before' },
      { src: `${base}images/ram2500after.jpg`,  caption: 'After' },
    ],
    dodge: [
      { src: `${base}images/dodgeBefore1.jpg`, caption: 'Before' },
      { src: `${base}images/dodgeBefore2.jpg`, caption: 'Before — rolling shot' },
      { src: `${base}images/dodgeAfter1.jpg`,  caption: 'After — fender flares' },
      { src: `${base}images/dodgeAfter2.jpg`,  caption: 'After — side profile' },
    ],
    brakes: [
      { src: `${base}images/brakesBefore.jpg`, caption: 'Before — worn rotors' },
      { src: `${base}images/brakesAfter.jpg`,  caption: 'After — fresh rotors' },
    ],
  };

  let currentProject = '';
  let currentIndex = 0;

  const lightbox  = document.getElementById('lightbox')!;
  const lbImg     = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lightbox-caption')!;
  const lbCounter = document.getElementById('lightbox-counter')!;
  const lbClose   = document.getElementById('lightbox-close')!;
  const lbPrev    = document.getElementById('lightbox-prev')!;
  const lbNext    = document.getElementById('lightbox-next')!;

  function showImage(projectId: string, index: number) {
    currentProject = projectId;
    const images = projectData[projectId];
    currentIndex = (index + images.length) % images.length;
    lbImg.src = images[currentIndex].src;
    lbImg.alt = images[currentIndex].caption;
    lbCaption.textContent = images[currentIndex].caption;
    lbCounter.textContent = `${currentIndex + 1} / ${images.length}`;
  }

  function openLightbox(projectId: string, index: number) {
    showImage(projectId, index);
    lightbox.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    document.body.style.overflow = '';
  }

  // Cover clicks
  document.querySelectorAll('[data-project]').forEach(el => {
    if (el.classList.contains('thumbnail-btn')) return;
    el.addEventListener('click', () => openLightbox(el.getAttribute('data-project')!, 0));
    el.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter') openLightbox(el.getAttribute('data-project')!, 0);
    });
  });

  // Thumbnail clicks
  document.querySelectorAll('.thumbnail-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      openLightbox(
        btn.getAttribute('data-project')!,
        parseInt(btn.getAttribute('data-index')!, 10)
      );
    });
  });

  lbClose.addEventListener('click', closeLightbox);
  lbPrev.addEventListener('click', () => showImage(currentProject, currentIndex - 1));
  lbNext.addEventListener('click', () => showImage(currentProject, currentIndex + 1));
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });

  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape')     closeLightbox();
    if (e.key === 'ArrowLeft')  showImage(currentProject, currentIndex - 1);
    if (e.key === 'ArrowRight') showImage(currentProject, currentIndex + 1);
  });

  // Category filter
  const filterBtns = document.querySelectorAll('.portfolio-filter');
  const items = document.querySelectorAll('.portfolio-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      filterBtns.forEach(b => {
        b.classList.remove('bg-accent-500', 'border-accent-500', 'text-white');
        b.classList.add('border-brand-500', 'text-warm-400');
      });
      btn.classList.add('bg-accent-500', 'border-accent-500', 'text-white');
      btn.classList.remove('border-brand-500', 'text-warm-400');
      items.forEach(item => {
        const cat = item.getAttribute('data-category');
        (item as HTMLElement).style.display = filter === 'all' || cat === filter ? '' : 'none';
      });
    });
  });
</script>
