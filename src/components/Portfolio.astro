      { src: `${base}images/tacomaBefore.jpg`, caption: 'Before' },
      { src: `${base}images/tacomaAfter.jpg`,  caption: 'After' },
    ],
  },
  {
    id: 'ram',
    title: 'Dodge Ram 2500',
    category: 'body',
