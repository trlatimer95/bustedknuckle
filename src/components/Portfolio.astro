  {
    id: 'camaro',
    title: "'73 Camaro Z28",
    category: 'restoration',
    description: 'Full restoration and respray — stripped from blue, rust-repaired, and brought back to life in orange with Z28 stripes.',
    cover: `${base}images/camaro/camaro-06-finished-front.jpg`,
    images: [
      { src: `${base}images/camaro/camaro-01-before.jpg`,        caption: 'Before — original blue paint' },
      { src: `${base}images/camaro/camaro-02-stripped.jpg`,      caption: 'Stripped down in the shop' },
