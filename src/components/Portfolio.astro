    cover: `${base}images/rangerAfter.jpg`,
    images: [
      { src: `${base}images/rangerBefore1.jpg`, caption: 'Before' },
      { src: `${base}images/rangerBefore2.jpg`, caption: 'Before — detail' },
      { src: `${base}images/rangerAfter.jpg`,   caption: 'After' },
    ],
  },
  {
    id: 'tacoma2',
    title: "Toyota Pickup Custom Paint",
    category: 'paint',
    description: 'Custom blue paint on an early-90s Toyota compact pickup.',
    cover: `${base}images/tacoma2After1.jpg`,
    images: [
      { src: `${base}images/tacoma2Before1.jpg`, caption: 'Before' },
      { src: `${base}images/tacoma2Before2.jpg`, caption: 'Before — detail' },
      { src: `${base}images/tacoma2Before3.jpg`, caption: 'Before — rear' },
      { src: `${base}images/tacoma2After1.jpg`,  caption: 'After' },
      { src: `${base}images/tacoma2After2.jpg`,  caption: 'After — detail' },
      { src: `${base}images/tacoma2After3.jpg`,  caption: 'After — rear' },
    ],
  },
  {
    id: 'pickup',
    title: "Classic Ford Pickup",
    category: 'restoration',
    description: 'Respray on a late-70s Ford F-series — solid blue with a lifted stance.',
    cover: `${base}images/pickupAfter1.jpg`,
    images: [
      { src: `${base}images/pickupBefore1.jpg`, caption: 'Before' },
      { src: `${base}images/pickupBefore2.jpg`, caption: 'Before — detail' },
      { src: `${base}images/pickupBefore3.jpg`, caption: 'Before — rear' },
      { src: `${base}images/pickupAfter1.jpg`,  caption: 'After' },
      { src: `${base}images/pickupAfter2.jpg`,  caption: 'After — detail' },
    ],
  },
  {
    id: 'f350',
    title: 'Ford F-350 Super Duty',
    category: 'body',
    description: 'Body repair and respray on a Super Duty — back to showroom clean.',
    cover: `${base}images/f350after.jpg`,
    images: [
      { src: `${base}images/f350Before.jpg`,  caption: 'Before' },
      { src: `${base}images/f350during.jpg`,  caption: 'During repair' },
      { src: `${base}images/f350after.jpg`,   caption: 'After' },
    ],
  },
  {
    id: 'f150',
    title: 'Ford F-150',
    category: 'body',
    description: 'Paint and body work on a crew cab F-150.',
    cover: `${base}images/f150after.jpg`,
    images: [
      { src: `${base}images/f150before.jpg`,  caption: 'Before' },
      { src: `${base}images/f150before2.jpg`, caption: 'Before — detail' },
      { src: `${base}images/f150during.jpg`,  caption: 'During repair' },
      { src: `${base}images/f150after.jpg`,   caption: 'After' },
    ],
  },
  {
    id: 'gmc',
    title: 'GMC Sierra 2500HD',
    category: 'body',
