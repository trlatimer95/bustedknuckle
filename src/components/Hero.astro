---

---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background gradient overlay (will sit on top of a future background image) -->
  <div class="absolute inset-0 bg-gradient-to-b from-brand-900/80 via-brand-900/60 to-brand-900 z-10"></div>

  <!-- Placeholder background pattern (replace with hero image) -->
  <div class="absolute inset-0 bg-brand-800">
    <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.4&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <!-- Content -->
  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center pt-20">
    <!-- Accent line -->
    <div class="w-16 h-1 bg-accent-500 mx-auto mb-8"></div>

    <h1 class="font-heading font-800 text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-white leading-tight tracking-wider">
      Busted Knuckle
      <span class="block text-accent-400 mt-2">Auto Repair & Painting</span>
    </h1>

    <p class="mt-6 sm:mt-8 text-lg sm:text-xl md:text-2xl text-warm-300 max-w-3xl mx-auto font-body leading-relaxed">
      Where metal meets mastery. High-end custom paint, expert body work, and classic car restoration in Lewiston, Idaho.
    </p>

    <!-- CTAs -->
    <div class="mt-10 sm:mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#portfolio" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-accent-500 hover:bg-accent-400 text-white px-8 py-4 rounded-sm font-heading font-700 text-base tracking-widest uppercase transition-colors">
        View Our Work
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
      <a href="#contact" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 border-2 border-warm-400 hover:border-accent-400 text-warm-200 hover:text-accent-400 px-8 py-4 rounded-sm font-heading font-700 text-base tracking-widest uppercase transition-colors">
        Get a Quote
      </a>
    </div>

    <!-- Location badge -->
    <div class="mt-12 sm:mt-16 inline-flex items-center gap-2 text-warm-400 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <span>Lewiston, Idaho &mdash; Serving the Lewis-Clark Valley</span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-warm-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
