---
const testimonials = [
  {
    quote: "The paint work on my '69 Camaro was absolutely stunning. These guys understand what car enthusiasts want and they deliver beyond expectations.",
    name: 'Satisfied Customer',
    vehicle: '1969 Camaro',
    stars: 5,
  },
  {
    quote: "Honest, fair, and the quality of work speaks for itself. I won't take my trucks anywhere else. True craftsmen who care about what they do.",
    name: 'Happy Client',
    vehicle: 'Chevy C10',
    stars: 5,
  },
  {
    quote: "From the initial conversation to the final reveal, the experience was top-notch. The custom paint job on my hot rod has won multiple show awards.",
    name: 'Repeat Customer',
    vehicle: 'Custom Hot Rod',
    stars: 5,
  },
];
---

<section class="py-20 sm:py-28 bg-brand-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="w-12 h-1 bg-accent-500 mx-auto mb-6"></div>
      <h2 class="font-heading font-800 text-3xl sm:text-4xl md:text-5xl text-white tracking-wider">
        What People Say
      </h2>
      <p class="mt-4 text-warm-300 text-lg max-w-2xl mx-auto">
        Our reputation is built on quality work and honest service. Here's what our customers have to say.
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-brand-700/30 border border-brand-600/30 rounded-sm p-6 sm:p-8 relative">
          <!-- Quote mark -->
          <div class="absolute top-4 right-6 text-accent-500/20 text-6xl font-heading leading-none">"</div>

          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: testimonial.stars }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent-400" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <blockquote class="text-warm-200 leading-relaxed italic mb-6">
            "{testimonial.quote}"
          </blockquote>

          <div class="border-t border-brand-600/30 pt-4">
            <div class="font-heading font-600 text-white tracking-wider text-sm">{testimonial.name}</div>
            <div class="text-warm-400 text-xs mt-1">{testimonial.vehicle}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Facebook Reviews Link -->
    <div class="text-center mt-10">
      <a
        href="https://www.facebook.com/profile.php?id=61565656770852"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-warm-400 hover:text-accent-400 text-sm transition-colors"
      >
        Read more reviews on Facebook
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</section>
