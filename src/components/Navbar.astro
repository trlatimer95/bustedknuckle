---
const base = import.meta.env.BASE_URL;
const navLinks = [
  { label: 'Services', href: '#services' },
  { label: 'Portfolio', href: '#portfolio' },
  { label: 'About', href: '#about' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-brand-900/95 backdrop-blur-sm border-b border-brand-700/50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16 sm:h-20">
    <!-- Logo / Brand -->
    <a href={base} class="flex items-center gap-3 group">
      <img src={`${base}images/logo.jpg`} alt="Busted Knuckle Auto Repair and Painting" class="h-10 sm:h-14 w-auto rounded-sm" />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a href={link.href} class="font-heading text-sm tracking-widest uppercase text-warm-300 hover:text-accent-400 transition-colors">
          {link.label}
        </a>
      ))}
    </div>

    <!-- Phone CTA -->
    <a href="tel:+12085536155" class="hidden sm:flex items-center gap-2 bg-accent-500 hover:bg-accent-400 text-white px-4 py-2 rounded-sm font-heading font-600 text-sm tracking-wider transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      (208) 553-6155
    </a>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden text-warm-200 hover:text-accent-400 transition-colors" aria-label="Toggle menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-brand-800 border-t border-brand-700/50">
    <div class="px-4 py-4 flex flex-col gap-3">
      {navLinks.map((link) => (
        <a href={link.href} class="mobile-nav-link font-heading text-base tracking-widest uppercase text-warm-300 hover:text-accent-400 py-2 transition-colors">
          {link.label}
        </a>
      ))}
      <a href="tel:+12085536155" class="flex items-center gap-2 bg-accent-500 hover:bg-accent-400 text-white px-4 py-3 rounded-sm font-heading font-600 text-sm tracking-wider transition-colors justify-center mt-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        (208) 553-6155
      </a>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
